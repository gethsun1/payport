generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?
  authProvider  String
  walletAddress String    @unique
  invoices      Invoice[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Merchant {
  id                String    @id @default(cuid())
  displayName       String
  settlementAddress String
  products          Product[]
  invoices          Invoice[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Product {
  id          String    @id @default(cuid())
  merchantId  String
  merchant    Merchant  @relation(fields: [merchantId], references: [id])
  name        String
  description String
  priceUsd    Decimal   @db.Decimal(12, 2)
  unlockType  String
  unlockValue String?
  active      Boolean   @default(true)
  invoices    Invoice[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Invoice {
  id              String           @id @default(cuid())
  merchantId      String
  merchant        Merchant         @relation(fields: [merchantId], references: [id])
  productId       String?
  product         Product?         @relation(fields: [productId], references: [id])
  buyerUserId     String?
  buyerUser       User?            @relation(fields: [buyerUserId], references: [id])
  amountUsd       Decimal          @db.Decimal(12, 2)
  status          String           @default("open")
  expiresAt       DateTime?
  paymentAttempts PaymentAttempt[]
  settlements     Settlement[]
  receipts        Receipt[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([merchantId])
  @@index([status])
}

model PaymentAttempt {
  id                    String       @id @default(cuid())
  invoiceId             String
  invoice               Invoice      @relation(fields: [invoiceId], references: [id])
  buyerAddress          String
  uaAddress             String?
  sourceAsset           String?
  destinationChainId    Int
  particleTransactionId String?
  rootHash              String?
  userOpsJson           Json?
  authorizationCount    Int?
  status                String       @default("created")
  errorMessage          String?
  settlements           Settlement[]
  receipts              Receipt[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  @@index([invoiceId])
  @@index([status])
  @@index([particleTransactionId])
}

model Settlement {
  id               String         @id @default(cuid())
  invoiceId        String
  invoice          Invoice        @relation(fields: [invoiceId], references: [id])
  paymentAttemptId String
  paymentAttempt   PaymentAttempt @relation(fields: [paymentAttemptId], references: [id])
  chainId          Int
  contractAddress  String
  txHash           String         @unique
  blockNumber      BigInt?
  eventName        String
  status           String
  receipts         Receipt[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([invoiceId])
  @@index([paymentAttemptId])
}

model Receipt {
  id                    String          @id @default(cuid())
  invoiceId             String
  invoice               Invoice         @relation(fields: [invoiceId], references: [id])
  paymentAttemptId      String
  paymentAttempt        PaymentAttempt  @relation(fields: [paymentAttemptId], references: [id])
  settlementId          String?
  settlement            Settlement?     @relation(fields: [settlementId], references: [id])
  buyerAddress          String
  merchantAddress       String
  amountUsd             Decimal         @db.Decimal(12, 2)
  particleTransactionId String?
  settlementTxHash      String?
  unlockStatus          String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@index([invoiceId])
  @@index([paymentAttemptId])
}
