{
  "name": "@payport/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npm run build --workspace @payport/shared && prisma generate && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "npm run build --workspace @payport/shared && tsc -p tsconfig.json --noEmit",
    "typecheck": "npm run build --workspace @payport/shared && tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@payport/shared": "file:../../packages/shared",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.7",
    "fastify": "^4.29.1",
    "viem": "^2.23.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
