{
  "name": "payport",
  "version": "0.1.0",
  "private": true,
  "description": "PayPort monorepo for consumer-grade cross-chain checkout.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @payport/api",
    "dev:web": "npm run dev --workspace @payport/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace @payport/api",
    "prisma:migrate": "npm run prisma:migrate --workspace @payport/api",
    "seed": "npm run seed --workspace @payport/api",
    "contracts:build": "forge build --root contracts",
    "contracts:test": "forge test --root contracts",
    "contracts:clean": "forge clean --root contracts",
    "contracts:export-abi": "node scripts/export-payport-settlement-abi.mjs"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0"
  }
}
